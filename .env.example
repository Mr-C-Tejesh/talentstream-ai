# Environment Configuration Example

# Groq API (FREE) - Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Google Gemini API (free tier)
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (paid)
# OPENAI_API_KEY=your_openai_api_key_here

# App Settings
ENV=development
DEBUG=True
